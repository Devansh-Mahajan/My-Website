---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BlogCard from '../components/BlogCard.astro';
import { QUARTZ_URL, SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';
import { getUrl } from '../utils/url';

const notes = {
	home:        QUARTZ_URL,
	eecs:        `${QUARTZ_URL}200-ETH-Zurich/ETH-BSc-EECS---Overview`,
	math:        `${QUARTZ_URL}300-IMO-+-Putnam/Strategies-in-problem-solving`,
	programming: `${QUARTZ_URL}400-IOI/Competitive-Programming`,
	books:       `${QUARTZ_URL}500-Book/Book-Notes`,
	quant:       `${QUARTZ_URL}700-Quant/Quantitative-Work`,
	projects:    `${QUARTZ_URL}800-Projects/Projects`,
};

const posts = (await getCollection('blog'))
	.filter((post) => post.data.publish)
	.sort((a, b) => {
		const dateA = a.data.created_date?.valueOf() ?? 0;
		const dateB = b.data.created_date?.valueOf() ?? 0;
		return dateB - dateA;
	})
	.slice(0, 3);

const hasPosts = posts.length > 0;

const selectedWork = [
	{
		title: 'ETH Zurich EECS Notebook',
		meta: 'Circuits · Signals · Systems',
		description: 'EECS coursework notes — digital circuits, signal processing, linear systems, and computer architecture.',
		href: notes.eecs,
	},
	{
		title: 'Competitive Programming',
		meta: 'Algorithms · Complexity',
		description: 'Problem solving notes, algorithm templates, and contest techniques at IOI difficulty.',
		href: notes.programming,
	},
	{
		title: 'Projects',
		meta: 'Hardware · Software · Quant',
		description: 'Project logs across hardware, software systems, and quantitative experiments.',
		href: notes.projects,
	},
];

const noteLinks = [
	{ label: 'ETH Zurich EECS',        href: notes.eecs },
	{ label: 'Problem Solving',         href: notes.math },
	{ label: 'Competitive Programming', href: notes.programming },
	{ label: 'Book Notes',              href: notes.books },
	{ label: 'Quantitative Work',       href: notes.quant },
	{ label: 'Projects',                href: notes.projects },
];

const focusAreas = [
	{ idx: '01', title: 'Electronics',       description: 'Circuits, signals, digital logic, and physical systems.' },
	{ idx: '02', title: 'Mathematics',       description: 'Proofs, linear algebra, calculus, probability, and problem solving.' },
	{ idx: '03', title: 'Software Systems',  description: 'Clean implementation, automation, infrastructure, and data workflows.' },
	{ idx: '04', title: 'Quantitative Work', description: 'Modelling, backtesting, statistics, and computational experiments.' },
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>

			<!-- ── HERO ─────────────────────────────────── -->
			<section class="hero" aria-labelledby="hero-name">

				<div class="eth-badge" aria-label="Currently enrolled at ETH Zürich, EECS">
					<span class="ping-wrapper" aria-hidden="true">
						<span class="ping-ring"></span>
						<span class="ping-dot"></span>
					</span>
					ETH Z&uuml;rich &middot; EECS
				</div>

				<h1 id="hero-name">Devansh<br />Mahajan</h1>

				<p class="lead">
					Electrical engineering and mathematics at ETH Z&uuml;rich.
					Every note, experiment, and build is public.
				</p>

				<div class="hero-actions">
					<a class="btn-primary" href={notes.home} target="_blank" rel="noreferrer">
						Browse Notes
						<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17L17 7m0 0H7m10 0v10"/></svg>
					</a>
					<a class="btn-ghost" href="https://github.com/Devansh-Mahajan" target="_blank" rel="noreferrer">GitHub</a>
					<a class="btn-ghost" href="https://www.linkedin.com/in/devansh-mahajan-2b2b99185/" target="_blank" rel="noreferrer">LinkedIn</a>
				</div>

				<p class="hero-meta" aria-label="Status">
					<span>BSc Candidate</span>
					<span class="meta-sep" aria-hidden="true">/</span>
					<span>Spring 2026</span>
					<span class="meta-sep" aria-hidden="true">/</span>
					<span>Z&uuml;rich</span>
				</p>

			</section>

			<!-- ── 01 — SELECTED WORK ────────────────────── -->
			<section class="section" aria-labelledby="work-heading">
				<header class="section-header">
					<span class="section-num">01</span>
					<h2 id="work-heading">Selected Work</h2>
				</header>

				<div class="work-grid">
					{selectedWork.map((item, i) => (
						<a
							class="work-card"
							href={item.href}
							target="_blank"
							rel="noreferrer"
							style={`animation-delay:${0.05 + i * 0.07}s`}
						>
							<p class="card-meta">{item.meta}</p>
							<h3>{item.title}</h3>
							<p class="card-desc">{item.description}</p>
							<span class="card-arrow" aria-hidden="true">
								<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
							</span>
						</a>
					))}
				</div>

				<nav class="notes-nav" aria-label="Notes index">
					<span class="notes-nav-label">Browse</span>
					<div class="note-tags" role="list">
						{noteLinks.map((link) => (
							<a class="note-tag" href={link.href} target="_blank" rel="noreferrer" role="listitem">
								{link.label}
							</a>
						))}
					</div>
					<a class="notes-all-link" href={notes.home} target="_blank" rel="noreferrer">
						All notes
						<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17L17 7m0 0H7m10 0v10"/></svg>
					</a>
				</nav>
			</section>

			<!-- ── 02 — FOCUS ────────────────────────────── -->
			<section class="section" aria-labelledby="focus-heading">
				<header class="section-header">
					<span class="section-num">02</span>
					<h2 id="focus-heading">Focus</h2>
				</header>
				<div class="focus-grid">
					{focusAreas.map((area) => (
						<div class="focus-cell">
							<span class="cell-idx">{area.idx}</span>
							<strong>{area.title}</strong>
							<p>{area.description}</p>
						</div>
					))}
				</div>
			</section>

			<!-- ── 03 — WRITING ──────────────────────────── -->
			{hasPosts && (
				<section class="section" aria-labelledby="writing-heading">
					<header class="section-header">
						<span class="section-num">03</span>
						<h2 id="writing-heading">Writing</h2>
					</header>
					<div class="post-grid">
						{posts.map((post) => (
							<BlogCard
								title={post.data.title}
								description={post.data.description}
								date={post.data.created_date}
								slug={post.id}
							/>
						))}
					</div>
					<a class="more-link" href={getUrl('/blog')}>
						All writing
						<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
					</a>
				</section>
			)}

		</main>
		<Footer />
	</body>
</html>


<style>
	/* ═══════════════════════════════════════════════════════
	   KEYFRAMES
	   ═══════════════════════════════════════════════════════ */

	@keyframes fadeUp {
		from { opacity: 0; transform: translateY(12px); }
		to   { opacity: 1; transform: translateY(0); }
	}

	@keyframes ping {
		75%, 100% {
			transform: scale(2.2);
			opacity: 0;
		}
	}

	/* ═══════════════════════════════════════════════════════
	   LAYOUT
	   ═══════════════════════════════════════════════════════ */

	main {
		max-width: 960px;
		margin: 0 auto;
		padding: 0 1.5rem 8rem;
	}

	/* ═══════════════════════════════════════════════════════
	   HERO
	   ═══════════════════════════════════════════════════════ */

	.hero {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		padding: 6rem 0 5.5rem;
	}

	/* ── ETH Badge with ping ── */
	.eth-badge {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		margin-bottom: 2rem;
		padding: 0.35rem 0.85rem 0.35rem 0.65rem;
		background: rgb(var(--gray-light));
		border: 1px solid rgba(var(--gray), 0.18);
		border-radius: 999px;
		font-size: 0.78rem;
		font-weight: 500;
		letter-spacing: -0.005em;
		color: rgb(var(--black));
		animation: fadeUp 0.5s cubic-bezier(0.22, 1, 0.36, 1) 0s both;
	}

	[data-theme='dark'] .eth-badge {
		background: rgba(var(--gray-light), 0.6);
	}

	.ping-wrapper {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 9px;
		height: 9px;
		flex-shrink: 0;
	}

	.ping-ring {
		position: absolute;
		inset: 0;
		border-radius: 50%;
		background: #30d158;
		animation: ping 1.8s cubic-bezier(0, 0, 0.2, 1) infinite;
	}

	.ping-dot {
		position: relative;
		width: 7px;
		height: 7px;
		background: #30d158;
		border-radius: 50%;
		flex-shrink: 0;
	}

	/* ── Name ── */
	h1 {
		margin: 0 0 1.25rem;
		font-size: clamp(4rem, 10vw, 7rem);
		font-weight: 700;
		line-height: 0.92;
		letter-spacing: -0.04em;
		color: rgb(var(--black));
		animation: fadeUp 0.6s cubic-bezier(0.22, 1, 0.36, 1) 0.06s both;
	}

	/* ── Lead ── */
	.lead {
		max-width: 440px;
		margin: 0 0 2.25rem;
		font-size: 1.0625rem;
		line-height: 1.68;
		color: rgb(var(--gray));
		font-weight: 400;
		animation: fadeUp 0.6s cubic-bezier(0.22, 1, 0.36, 1) 0.12s both;
	}

	/* ── CTA row ── */
	.hero-actions {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		flex-wrap: wrap;
		animation: fadeUp 0.6s cubic-bezier(0.22, 1, 0.36, 1) 0.18s both;
	}

	/* ── Meta line ── */
	.hero-meta {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		margin: 1.25rem 0 0;
		font-family: var(--font-mono);
		font-size: 0.7rem;
		letter-spacing: 0.02em;
		color: rgb(var(--gray));
		opacity: 0.55;
		animation: fadeUp 0.6s cubic-bezier(0.22, 1, 0.36, 1) 0.24s both;
	}

	.meta-sep { opacity: 0.45; }

	/* ═══════════════════════════════════════════════════════
	   BUTTONS
	   ═══════════════════════════════════════════════════════ */

	.btn-primary {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		padding: 0.575rem 1.1rem;
		background: var(--accent);
		color: #fff !important;
		border-radius: 999px;
		font-size: 0.875rem;
		font-weight: 500;
		letter-spacing: -0.005em;
		text-decoration: none !important;
		transition: opacity 0.18s ease, transform 0.18s ease;
	}
	.btn-primary:hover { opacity: 0.85; transform: translateY(-1px); }

	.btn-ghost {
		display: inline-flex;
		align-items: center;
		padding: 0.575rem 1.1rem;
		background: transparent;
		border: 1px solid rgba(var(--gray), 0.28);
		color: rgb(var(--black)) !important;
		border-radius: 999px;
		font-size: 0.875rem;
		font-weight: 500;
		letter-spacing: -0.005em;
		text-decoration: none !important;
		transition: background 0.18s ease, border-color 0.18s ease, transform 0.18s ease;
	}
	.btn-ghost:hover {
		background: rgba(var(--gray-light), 0.9);
		border-color: rgba(var(--gray), 0.45);
		transform: translateY(-1px);
	}

	/* ═══════════════════════════════════════════════════════
	   SECTIONS
	   ═══════════════════════════════════════════════════════ */

	.section {
		padding: 5rem 0;
		border-top: 1px solid rgba(var(--gray), 0.14);
	}

	.section-header {
		display: flex;
		align-items: baseline;
		gap: 1rem;
		margin-bottom: 2.75rem;
	}

	.section-num {
		font-family: var(--font-mono);
		font-size: 0.68rem;
		font-weight: 400;
		letter-spacing: 0.05em;
		color: var(--accent);
		opacity: 0.75;
		flex-shrink: 0;
		padding-top: 0.2rem;
	}

	.section-header h2 {
		margin: 0;
		font-size: clamp(1.625rem, 3.5vw, 2.25rem);
		font-weight: 600;
		line-height: 1.1;
		letter-spacing: -0.025em;
		color: rgb(var(--black));
	}

	/* ═══════════════════════════════════════════════════════
	   WORK CARDS
	   ═══════════════════════════════════════════════════════ */

	.work-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1px;
		background: rgba(var(--gray), 0.12);
		border-radius: 16px;
		overflow: hidden;
		border: 1px solid rgba(var(--gray), 0.12);
	}

	.work-card {
		position: relative;
		display: flex;
		flex-direction: column;
		padding: 1.75rem;
		background: rgb(var(--bg));
		text-decoration: none !important;
		color: rgb(var(--black)) !important;
		transition:
			background 0.2s ease,
			transform  0.2s cubic-bezier(0.22, 1, 0.36, 1);
		animation: fadeUp 0.55s cubic-bezier(0.22, 1, 0.36, 1) both;
	}

	.work-card:hover {
		background: rgb(var(--gray-light));
	}

	[data-theme='dark'] .work-card { background: rgb(var(--bg)); }
	[data-theme='dark'] .work-card:hover { background: rgba(var(--gray-light), 0.5); }

	.card-meta {
		margin: 0 0 0.6rem;
		font-family: var(--font-mono);
		font-size: 0.67rem;
		font-weight: 400;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		color: var(--accent);
		opacity: 0.8;
	}

	.work-card h3 {
		margin: 0 0 0.5rem;
		font-size: 0.9375rem;
		font-weight: 600;
		line-height: 1.3;
		letter-spacing: -0.012em;
	}

	.card-desc {
		flex: 1;
		margin: 0;
		font-size: 0.875rem;
		line-height: 1.65;
		color: rgb(var(--gray));
	}

	.card-arrow {
		display: flex;
		align-items: center;
		margin-top: 1.5rem;
		color: var(--accent);
		opacity: 0.7;
		transition: transform 0.2s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.2s ease;
	}
	.work-card:hover .card-arrow { transform: translateX(4px); opacity: 1; }

	/* ═══════════════════════════════════════════════════════
	   NOTES NAV
	   ═══════════════════════════════════════════════════════ */

	.notes-nav {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		margin-top: 1.25rem;
		padding: 0.75rem 1rem;
		border: 1px solid rgba(var(--gray), 0.14);
		border-radius: 12px;
		flex-wrap: wrap;
	}

	.notes-nav-label {
		font-family: var(--font-mono);
		font-size: 0.66rem;
		font-weight: 400;
		letter-spacing: 0.07em;
		text-transform: uppercase;
		color: rgb(var(--gray));
		white-space: nowrap;
		padding-right: 0.4rem;
		border-right: 1px solid rgba(var(--gray), 0.2);
	}

	.note-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.35rem;
		flex: 1;
	}

	.note-tag {
		padding: 0.25rem 0.6rem;
		border: 1px solid rgba(var(--gray), 0.18);
		border-radius: 999px;
		font-size: 0.775rem;
		font-weight: 500;
		color: rgb(var(--black)) !important;
		text-decoration: none !important;
		transition: border-color 0.15s ease, color 0.15s ease;
	}
	.note-tag:hover { border-color: var(--accent); color: var(--accent) !important; }

	.notes-all-link {
		display: inline-flex;
		align-items: center;
		gap: 0.25rem;
		margin-left: auto;
		font-size: 0.8rem;
		font-weight: 500;
		color: var(--accent) !important;
		text-decoration: none !important;
		white-space: nowrap;
		transition: opacity 0.15s ease;
	}
	.notes-all-link:hover { opacity: 0.7; }

	/* ═══════════════════════════════════════════════════════
	   FOCUS GRID
	   ═══════════════════════════════════════════════════════ */

	.focus-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1px;
		background: rgba(var(--gray), 0.12);
		border-radius: 16px;
		overflow: hidden;
		border: 1px solid rgba(var(--gray), 0.12);
	}

	.focus-cell {
		padding: 1.875rem 2rem;
		background: rgb(var(--bg));
		transition: background 0.2s ease;
	}

	.focus-cell:hover { background: rgb(var(--gray-light)); }

	[data-theme='dark'] .focus-cell { background: rgb(var(--bg)); }
	[data-theme='dark'] .focus-cell:hover { background: rgba(var(--gray-light), 0.4); }

	.cell-idx {
		display: block;
		margin-bottom: 0.65rem;
		font-family: var(--font-mono);
		font-size: 0.64rem;
		font-weight: 400;
		letter-spacing: 0.05em;
		color: var(--accent);
		opacity: 0.6;
	}

	.focus-cell strong {
		display: block;
		margin-bottom: 0.4rem;
		font-size: 0.9375rem;
		font-weight: 600;
		letter-spacing: -0.012em;
		color: rgb(var(--black));
	}

	.focus-cell p {
		margin: 0;
		font-size: 0.875rem;
		line-height: 1.65;
		color: rgb(var(--gray));
	}

	/* ═══════════════════════════════════════════════════════
	   WRITING
	   ═══════════════════════════════════════════════════════ */

	.post-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1rem;
		margin-bottom: 1.5rem;
	}

	.more-link {
		display: inline-flex;
		align-items: center;
		gap: 0.3rem;
		font-size: 0.875rem;
		font-weight: 500;
		color: var(--accent) !important;
		text-decoration: none !important;
		transition: opacity 0.15s ease;
	}
	.more-link:hover { opacity: 0.7; }

	/* ═══════════════════════════════════════════════════════
	   RESPONSIVE
	   ═══════════════════════════════════════════════════════ */

	@media (max-width: 760px) {
		main { padding: 0 1.25rem 5rem; }

		.hero { padding: 4rem 0 3.5rem; }

		h1 {
			font-size: clamp(3.25rem, 16vw, 4.5rem);
			letter-spacing: -0.035em;
			line-height: 0.93;
		}

		.section { padding: 3.5rem 0; }

		.work-grid   { grid-template-columns: 1fr; }
		.post-grid   { grid-template-columns: 1fr; }
		.focus-grid  { grid-template-columns: 1fr; }

		.notes-nav { gap: 0.4rem; }
		.notes-all-link { margin-left: 0; }
	}

	@media (max-width: 480px) {
		.hero { padding: 3rem 0 3rem; }
		.hero-actions { gap: 0.45rem; }
		.notes-nav-label { display: none; }
		.hero-meta { flex-wrap: wrap; }
	}
</style>
