---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BlogCard from '../components/BlogCard.astro';
import { QUARTZ_URL, SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';
import { getUrl } from '../utils/url';

const notes = {
	home:        QUARTZ_URL,
	eecs:        `${QUARTZ_URL}200-ETH-Zurich/ETH-BSc-EECS---Overview`,
	math:        `${QUARTZ_URL}300-IMO-+-Putnam/Strategies-in-problem-solving`,
	programming: `${QUARTZ_URL}400-IOI/Competitive-Programming`,
	books:       `${QUARTZ_URL}500-Book/Book-Notes`,
	sidequests:  `${QUARTZ_URL}600-Sidequests/Sidequests`,
	quant:       `${QUARTZ_URL}700-Quant/Quantitative-Work`,
	projects:    `${QUARTZ_URL}800-Projects/Projects`,
};

const posts = (await getCollection('blog'))
	.filter((post) => post.data.publish)
	.sort((a, b) => {
		const dateA = a.data.created_date?.valueOf() ?? 0;
		const dateB = b.data.created_date?.valueOf() ?? 0;
		return dateB - dateA;
	})
	.slice(0, 3);

const hasPosts = posts.length > 0;

const selectedWork = [
	{
		title: 'ETH Zurich EECS Notebook',
		meta: 'Circuits · Signals · Systems',
		description: 'EECS coursework notes — digital circuits, signal processing, linear systems, and computer architecture.',
		href: notes.eecs,
	},
	{
		title: 'Competitive Programming',
		meta: 'Algorithms · Complexity',
		description: 'Problem solving notes, algorithm templates, and contest techniques at IOI difficulty.',
		href: notes.programming,
	},
	{
		title: 'Projects',
		meta: 'Hardware · Software · Quant',
		description: 'Project logs across hardware, software systems, and quantitative experiments.',
		href: notes.projects,
	},
];

const noteLinks = [
	{ label: 'ETH Zurich EECS',        href: notes.eecs },
	{ label: 'Problem Solving',         href: notes.math },
	{ label: 'Competitive Programming', href: notes.programming },
	{ label: 'Book Notes',              href: notes.books },
	{ label: 'Sidequests',              href: notes.sidequests },
	{ label: 'Quantitative Work',       href: notes.quant },
	{ label: 'Projects',                href: notes.projects },
];

const focusAreas = [
	{ idx: '01', title: 'Electronics',       description: 'Circuits, signals, digital logic, and physical systems.' },
	{ idx: '02', title: 'Mathematics',       description: 'Proofs, linear algebra, calculus, probability, and problem solving.' },
	{ idx: '03', title: 'Software Systems',  description: 'Clean implementation, automation, infrastructure, and data workflows.' },
	{ idx: '04', title: 'Quantitative Work', description: 'Modelling, backtesting, statistics, and computational experiments.' },
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>

			<!-- ── HERO ─────────────────────────────────── -->
			<section class="hero" aria-labelledby="hero-name">

				<!-- PCB schematic: routes itself in on load, two calm signal pulses -->
				<svg class="pcb-bg" viewBox="0 0 520 600" fill="none"
				     preserveAspectRatio="xMaxYMid meet" aria-hidden="true">

					<!-- ══ TRACES ═══════════════════════════════════════ -->
					<g stroke="currentColor" stroke-width="1.1" fill="none" stroke-linecap="square">

						<!-- Rails + bus spine -->
						<path class="tr tr-1"   pathLength="1000" d="M 520 50 H 290"/>
						<path class="tr tr-2"   pathLength="1000" d="M 290 20 H 440"/>
						<path class="tr tr-2b"  pathLength="1000" d="M 480 20 H 520"/>
						<path class="tr tr-3"   pathLength="1000" d="M 290 20 V 50"/>
						<path class="tr tr-4"   pathLength="1000" d="M 290 50 V 565"/>
						<path class="tr tr-15"  pathLength="1000" d="M 290 565 V 583"/>

						<!-- U1 (FPGA, left): bus → right pin stubs -->
						<path class="tr tr-5"   pathLength="1000" d="M 290 133 H 238"/>
						<path class="tr tr-5b"  pathLength="1000" d="M 290 149 H 238"/>
						<path class="tr tr-5c"  pathLength="1000" d="M 290 165 H 238"/>
						<path class="tr tr-5d"  pathLength="1000" d="M 290 181 H 238"/>
						<!-- U1 left pin exits off-screen -->
						<path class="tr tr-6"   pathLength="1000" d="M 64 133 H 0"/>
						<path class="tr tr-6b"  pathLength="1000" d="M 64 149 H 0"/>
						<path class="tr tr-6c"  pathLength="1000" d="M 64 165 H 0"/>

						<!-- U2 (MCU, right): bus → left pin stubs -->
						<path class="tr tr-7"   pathLength="1000" d="M 290 128 H 314"/>
						<path class="tr tr-7b"  pathLength="1000" d="M 290 143 H 314"/>
						<path class="tr tr-7c"  pathLength="1000" d="M 290 158 H 314"/>
						<path class="tr tr-7d"  pathLength="1000" d="M 290 173 H 314"/>
						<!-- U2 right outputs -->
						<path class="tr tr-8"   pathLength="1000" d="M 430 128 H 520"/>
						<path class="tr tr-8b"  pathLength="1000" d="M 430 143 H 520"/>

						<!-- C1: VCC junction stub down, then GND lead -->
						<path class="tr tr-9"   pathLength="1000" d="M 372 50 V 60"/>
						<path class="tr tr-9b"  pathLength="1000" d="M 372 66 V 92"/>

						<!-- C2: branch off bus, GND lead -->
						<path class="tr tr-10"  pathLength="1000" d="M 290 265 H 452 V 272"/>
						<path class="tr tr-10b" pathLength="1000" d="M 452 278 V 302"/>

						<!-- R1: inline on trace at y=310 -->
						<path class="tr tr-11"  pathLength="1000" d="M 290 310 H 375"/>
						<path class="tr tr-11b" pathLength="1000" d="M 413 310 H 520"/>

						<!-- L1: left lead, arc bumps (4×), right lead -->
						<path class="tr tr-12"  pathLength="1000" d="M 290 375 H 352"/>
						<path class="tr tr-12c" pathLength="1000" stroke-linecap="round"
						      d="M 352 375 Q 361 362 370 375 Q 379 362 388 375 Q 397 362 406 375 Q 415 362 424 375"/>
						<path class="tr tr-12b" pathLength="1000" d="M 424 375 H 520"/>

						<!-- R2: inline at y=445 -->
						<path class="tr tr-13"  pathLength="1000" d="M 290 445 H 372"/>
						<path class="tr tr-13b" pathLength="1000" d="M 410 445 H 520"/>

					</g>

					<!-- ══ GND SYMBOLS ══════════════════════════════════ -->
					<g stroke="currentColor" stroke-width="0.9" stroke-linecap="round">
						<!-- Bus bottom -->
						<line x1="278" y1="586" x2="302" y2="586"/>
						<line x1="282" y1="591" x2="298" y2="591"/>
						<line x1="286" y1="596" x2="294" y2="596"/>
					</g>
					<g stroke="currentColor" stroke-width="0.75" stroke-linecap="round">
						<!-- C1 bottom -->
						<line x1="365" y1="93"  x2="379" y2="93"/>
						<line x1="368" y1="97"  x2="376" y2="97"/>
						<line x1="371" y1="101" x2="373" y2="101"/>
						<!-- C2 bottom -->
						<line x1="445" y1="304" x2="459" y2="304"/>
						<line x1="448" y1="308" x2="456" y2="308"/>
						<line x1="451" y1="312" x2="453" y2="312"/>
					</g>

					<!-- ══ VIAS — staggered pulse so nodes feel alive ══ -->
					<circle class="via-o" cx="290" cy="50"  r="5"/>  <circle class="via-i" cx="290" cy="50"  r="2"   style="animation-delay:0.0s"/>
					<circle class="via-o" cx="290" cy="20"  r="3.5"/><circle class="via-i" cx="290" cy="20"  r="1.5" style="animation-delay:0.6s"/>
					<circle class="via-o" cx="290" cy="265" r="3.5"/><circle class="via-i" cx="290" cy="265" r="1.5" style="animation-delay:1.2s"/>
					<circle class="via-o" cx="290" cy="310" r="4"/>  <circle class="via-i" cx="290" cy="310" r="1.8" style="animation-delay:0.4s"/>
					<circle class="via-o" cx="290" cy="375" r="4"/>  <circle class="via-i" cx="290" cy="375" r="1.8" style="animation-delay:1.8s"/>
					<circle class="via-o" cx="290" cy="445" r="3.5"/><circle class="via-i" cx="290" cy="445" r="1.5" style="animation-delay:0.9s"/>
					<circle class="via-o" cx="372" cy="50"  r="3.5"/><circle class="via-i" cx="372" cy="50"  r="1.5" style="animation-delay:1.5s"/>

					<!-- ══ U1: FPGA (schematic box, left of bus) ════════ -->
					<rect class="ic-box" x="78" y="116" width="160" height="90" rx="2"/>
					<circle class="ic-pin1" cx="86" cy="124" r="2.2"/>
					<line class="ic-pin" x1="238" y1="131" x2="252" y2="131"/>
					<line class="ic-pin" x1="238" y1="147" x2="252" y2="147"/>
					<line class="ic-pin" x1="238" y1="163" x2="252" y2="163"/>
					<line class="ic-pin" x1="238" y1="179" x2="252" y2="179"/>
					<line class="ic-pin" x1="78"  y1="131" x2="64"  y2="131"/>
					<line class="ic-pin" x1="78"  y1="147" x2="64"  y2="147"/>
					<line class="ic-pin" x1="78"  y1="163" x2="64"  y2="163"/>
					<line class="ic-div" x1="78" y1="176" x2="238" y2="176"/>
					<text class="ic-ref-lbl" x="158" y="168">U1</text>
					<text class="ic-val-lbl" x="158" y="182">FPGA</text>

					<!-- ══ U2: MCU (right of bus) ════════════════════════ -->
					<rect class="ic-box" x="328" y="112" width="88" height="74" rx="2"/>
					<circle class="ic-pin1" cx="336" cy="120" r="2"/>
					<line class="ic-pin" x1="328" y1="128" x2="314" y2="128"/>
					<line class="ic-pin" x1="328" y1="143" x2="314" y2="143"/>
					<line class="ic-pin" x1="328" y1="158" x2="314" y2="158"/>
					<line class="ic-pin" x1="328" y1="173" x2="314" y2="173"/>
					<line class="ic-pin" x1="416" y1="128" x2="430" y2="128"/>
					<line class="ic-pin" x1="416" y1="143" x2="430" y2="143"/>
					<line class="ic-div" x1="328" y1="155" x2="416" y2="155"/>
					<text class="ic-ref-lbl" x="372" y="147">U2</text>
					<text class="ic-val-lbl" x="372" y="161">MCU</text>

					<!-- ══ C1: Decoupling capacitor (VCC → GND) ═════════ -->
					<line class="ic-pin" x1="363" y1="60" x2="381" y2="60"/>
					<line class="ic-pin" x1="363" y1="66" x2="381" y2="66"/>
					<text class="comp-ref-lbl" x="388" y="61">C1</text>
					<text class="comp-val-lbl" x="388" y="72">100n</text>

					<!-- ══ C2: Bypass capacitor (bus branch → GND) ══════ -->
					<line class="ic-pin" x1="443" y1="272" x2="461" y2="272"/>
					<line class="ic-pin" x1="443" y1="278" x2="461" y2="278"/>
					<text class="comp-ref-lbl" x="466" y="277">C2</text>
					<text class="comp-val-lbl" x="466" y="288">10µ</text>

					<!-- ══ R1: Resistor 4.7k ═════════════════════════════ -->
					<rect class="ic-box r-box" x="375" y="303" width="38" height="14" rx="1.5"/>
					<text class="comp-ref-lbl" x="394" y="299">R1</text>
					<text class="comp-val-lbl" x="394" y="327">4.7k</text>

					<!-- ══ L1: Inductor 10µH (4 arc bumps) ══════════════ -->
					<!-- arc bumps drawn as tr-12c in trace group above -->
					<text class="comp-ref-lbl" x="388" y="357">L1</text>
					<text class="comp-val-lbl" x="388" y="390">10µH</text>

					<!-- ══ R2: Resistor 10k ══════════════════════════════ -->
					<rect class="ic-box r-box" x="372" y="438" width="38" height="14" rx="1.5"/>
					<text class="comp-ref-lbl" x="391" y="434">R2</text>
					<text class="comp-val-lbl" x="391" y="462">10k</text>

					<!-- ══ Y1: Crystal oscillator (inline on return rail) -->
					<rect class="ic-box" x="440" y="13" width="40" height="14" rx="2"/>
					<rect class="ic-box crys" x="448" y="15.5" width="24" height="9" rx="0.5"/>
					<text class="comp-ref-lbl" x="460" y="9">Y1</text>
					<text class="comp-val-lbl" x="460" y="33">16MHz</text>

					<!-- ══ SIGNALS ════════════════════════════════════════ -->
					<!-- sig-1: power rail → bus → R1 branch → right -->
					<path class="sig sig-1" d="M 520 50 H 290 V 310 H 520"/>
					<!-- sig-2: return rail → Y1 crystal -->
					<path class="sig sig-2" d="M 290 20 H 440"/>
					<!-- sig-3: bus → L1 inductor arcs → right -->
					<path class="sig sig-3" stroke-linecap="round"
					      d="M 290 375 H 352 Q 361 362 370 375 Q 379 362 388 375 Q 397 362 406 375 Q 415 362 424 375 H 520"/>
					<!-- sig-4: bus → through U2 layer → right output -->
					<path class="sig sig-4" d="M 290 143 H 520"/>

				</svg>

				<!-- Ghost: math/code equations wipe in and fade in the PCB region -->
				<div class="code-ghost" aria-hidden="true">
					<span class="cg cg-1">&#8711; &times; E = &#8722;&#8706;B/&#8706;t</span>
					<span class="cg cg-2">O(n log n)</span>
					<span class="cg cg-3">H(s) = Y(s) / X(s)</span>
					<span class="cg cg-4">&#8721; &#955;&#7522; = tr(A)</span>
				</div>

				<!-- Hero text content -->
				<div class="hero-content">

					<div class="eth-badge" aria-label="Currently enrolled at ETH Zürich, EECS">
						<span class="ping-wrapper" aria-hidden="true">
							<span class="ping-ring"></span>
							<span class="ping-dot"></span>
						</span>
						ETH Z&uuml;rich &middot; EECS
					</div>

					<h1 id="hero-name">Devansh<br />Mahajan</h1>

					<p class="lead">
						Electrical engineering and mathematics at ETH Z&uuml;rich.
						Every note, experiment, and build is public.
					</p>

					<div class="hero-actions">
						<a class="btn-primary" href={notes.home} target="_blank" rel="noreferrer">
							Browse Notes
							<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17L17 7m0 0H7m10 0v10"/></svg>
						</a>
						<a class="btn-ghost" href="https://github.com/Devansh-Mahajan" target="_blank" rel="noreferrer">GitHub</a>
						<a class="btn-ghost" href="https://www.linkedin.com/in/devansh-mahajan-2b2b99185/" target="_blank" rel="noreferrer">LinkedIn</a>
					</div>

					<p class="hero-meta" aria-label="Status">
						<span>BSc Candidate</span>
						<span class="meta-sep" aria-hidden="true">/</span>
						<span>Spring 2026</span>
						<span class="meta-sep" aria-hidden="true">/</span>
						<span>Z&uuml;rich</span>
					</p>

				</div>

			</section>

			<!-- ── 01 — SELECTED WORK ────────────────────── -->
			<section class="section" aria-labelledby="work-heading">
				<header class="section-header">
					<span class="section-num">01</span>
					<h2 id="work-heading">Selected Work</h2>
				</header>

				<div class="work-grid">
					{selectedWork.map((item, i) => (
						<a
							class="work-card"
							href={item.href}
							target="_blank"
							rel="noreferrer"
							style={`animation-delay:${0.05 + i * 0.07}s`}
						>
							<p class="card-meta">{item.meta}</p>
							<h3>{item.title}</h3>
							<p class="card-desc">{item.description}</p>
							<span class="card-arrow" aria-hidden="true">
								<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
							</span>
						</a>
					))}
				</div>

				<nav class="notes-nav" aria-label="Notes index">
					<span class="notes-nav-label">Browse</span>
					<div class="note-tags" role="list">
						{noteLinks.map((link) => (
							<a class="note-tag" href={link.href} target="_blank" rel="noreferrer" role="listitem">
								{link.label}
							</a>
						))}
					</div>
					<a class="notes-all-link" href={notes.home} target="_blank" rel="noreferrer">
						All notes
						<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17L17 7m0 0H7m10 0v10"/></svg>
					</a>
				</nav>
			</section>

			<!-- ── 02 — FOCUS ────────────────────────────── -->
			<section class="section" aria-labelledby="focus-heading">
				<header class="section-header">
					<span class="section-num">02</span>
					<h2 id="focus-heading">Focus</h2>
				</header>
				<div class="focus-grid">
					{focusAreas.map((area) => (
						<div class="focus-cell">
							<span class="cell-idx">{area.idx}</span>
							<strong>{area.title}</strong>
							<p>{area.description}</p>
						</div>
					))}
				</div>
			</section>

			<!-- ── 03 — WRITING ──────────────────────────── -->
			{hasPosts && (
				<section class="section" aria-labelledby="writing-heading">
					<header class="section-header">
						<span class="section-num">03</span>
						<h2 id="writing-heading">Writing</h2>
					</header>
					<div class="post-grid">
						{posts.map((post) => (
							<BlogCard
								title={post.data.title}
								description={post.data.description}
								date={post.data.created_date}
								slug={post.id}
							/>
						))}
					</div>
					<a class="more-link" href={getUrl('/blog')}>
						All writing
						<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
					</a>
				</section>
			)}

		</main>
		<Footer />
	</body>
</html>


<style>
	/* ═══════════════════════════════════════════════════════
	   KEYFRAMES
	   ═══════════════════════════════════════════════════════ */

	@keyframes fadeUp {
		from { opacity: 0; transform: translateY(12px); }
		to   { opacity: 1; transform: translateY(0); }
	}

	@keyframes ping {
		75%, 100% { transform: scale(2.2); opacity: 0; }
	}

	/* PCB traces draw themselves in on load (one-shot) */
	@keyframes drawTrace {
		from { stroke-dashoffset: 1000; }
		to   { stroke-dashoffset: 0; }
	}

	/* Universal signal dot — works on any path length */
	@keyframes sigPulse {
		0%   { stroke-dashoffset:    0; opacity: 0; }
		5%   { opacity: 0.9; }
		88%  { opacity: 0.9; }
		100% { stroke-dashoffset: -1000; opacity: 0; }
	}

	/* Via node activity pulse */
	@keyframes viaPulse {
		0%, 100% { opacity: 0.3; }
		50%      { opacity: 1;   }
	}

	/* Ghost code: clip-wipe in from left, linger, fade out */
	@keyframes codeReveal {
		0%   { clip-path: inset(0 100% 0 0); opacity: 0; }
		5%   { opacity: var(--ghost-vis, 0.07); }
		20%  { clip-path: inset(0 0% 0 0); }
		55%  { clip-path: inset(0 0% 0 0); opacity: var(--ghost-vis, 0.07); }
		70%  { opacity: 0; }
		78%  { clip-path: inset(0 100% 0 0); }
		100% { clip-path: inset(0 100% 0 0); opacity: 0; }
	}

	/* ═══════════════════════════════════════════════════════
	   TOKENS
	   ═══════════════════════════════════════════════════════ */

	:root { --ghost-vis: 0.13; }
	[data-theme='dark'] { --ghost-vis: 0.20; }

	/* ═══════════════════════════════════════════════════════
	   LAYOUT
	   ═══════════════════════════════════════════════════════ */

	main {
		max-width: 960px;
		margin: 0 auto;
		padding: 0 1.5rem 8rem;
	}

	/* ═══════════════════════════════════════════════════════
	   HERO
	   ═══════════════════════════════════════════════════════ */

	.hero {
		position: relative;
		overflow: hidden;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		padding: 6rem 0 5.5rem;
	}

	/* Content sits above the decorative layers */
	.hero-content {
		position: relative;
		z-index: 1;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
	}

	/* ── PCB schematic ── */
	.pcb-bg {
		position: absolute;
		right: -24px;
		top: 0;
		height: 100%;
		width: 52%;
		pointer-events: none;
		z-index: 0;
		color: rgba(0, 113, 227, 0.15);
		mask-image: linear-gradient(to right,
			transparent 0%,
			rgba(0,0,0,0.2) 22%,
			rgba(0,0,0,0.65) 52%,
			black 72%
		);
		-webkit-mask-image: linear-gradient(to right,
			transparent 0%,
			rgba(0,0,0,0.2) 22%,
			rgba(0,0,0,0.65) 52%,
			black 72%
		);
	}
	[data-theme='dark'] .pcb-bg { color: rgba(41, 151, 255, 0.28); }

	/* Traces */
	.tr {
		stroke-dasharray: 1000;
		stroke-dashoffset: 1000;
		animation: drawTrace 1.3s cubic-bezier(0.25, 0, 0.5, 1) forwards;
	}
	/* Rails + bus — establish the skeleton first */
	.tr-1   { animation-delay: 0.10s; }
	.tr-2   { animation-delay: 0.18s; }
	.tr-2b  { animation-delay: 0.25s; }
	.tr-3   { animation-delay: 0.28s; }
	.tr-4   { animation-delay: 0.38s; }
	/* C1 stub — branches off power rail early */
	.tr-9   { animation-delay: 0.50s; }
	.tr-9b  { animation-delay: 0.56s; }
	/* U1 + U2 connections — both ICs route simultaneously */
	.tr-5   { animation-delay: 0.62s; }
	.tr-7   { animation-delay: 0.62s; }
	.tr-5b  { animation-delay: 0.68s; }
	.tr-7b  { animation-delay: 0.68s; }
	.tr-5c  { animation-delay: 0.74s; }
	.tr-7c  { animation-delay: 0.74s; }
	.tr-5d  { animation-delay: 0.80s; }
	.tr-7d  { animation-delay: 0.80s; }
	/* IC outputs */
	.tr-8   { animation-delay: 0.88s; }
	.tr-8b  { animation-delay: 0.93s; }
	.tr-6   { animation-delay: 0.95s; }
	.tr-6b  { animation-delay: 1.00s; }
	.tr-6c  { animation-delay: 1.05s; }
	/* Lower component branches — cascade downward */
	.tr-10  { animation-delay: 1.10s; }
	.tr-10b { animation-delay: 1.16s; }
	.tr-11  { animation-delay: 1.22s; }
	.tr-11b { animation-delay: 1.28s; }
	.tr-12  { animation-delay: 1.34s; }
	.tr-12c { animation-delay: 1.40s; }
	.tr-12b { animation-delay: 1.52s; }
	.tr-13  { animation-delay: 1.56s; }
	.tr-13b { animation-delay: 1.62s; }
	.tr-15  { animation-delay: 1.70s; }

