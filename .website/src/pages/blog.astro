---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BlogCard from '../components/BlogCard.astro';
import { QUARTZ_URL } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
	.filter(post => post.data.publish)
	.sort((a, b) => {
		const dateA = a.data.created_date?.valueOf() ?? 0;
		const dateB = b.data.created_date?.valueOf() ?? 0;
		return dateB - dateA;
	});
---

<!doctype html>
<html lang="en">
<head>
	<BaseHead
		title="Writing — Devansh Mahajan"
		description="Essays and notes from EECS study, mathematics, and software systems work at ETH Zurich."
	/>
</head>
<body>
	<Header />
	<main>

		<!-- Page hero -->
		<section class="page-hero">
			<p class="eyebrow">
				<svg class="bolt-icon" viewBox="0 0 10 14" fill="currentColor" aria-hidden="true"><path d="M6.5 0L0 8h4.5L3 14l7-8.5H5.5L6.5 0z"/></svg>
				Writing
			</p>
			<h1>Essays &amp; notes.</h1>
			<p class="lead">Thinking across circuits, systems, and mathematics — published openly.</p>
		</section>

		<!-- Posts -->
		{posts.length > 0 ? (
			<section class="posts-section">
				<div class="posts-grid">
					{posts.map((post) => (
						<BlogCard
							title={post.data.title}
							description={post.data.description ?? undefined}
							date={post.data.created_date ?? undefined}
							slug={post.data.slug ?? post.id}
						/>
					))}
				</div>
			</section>
		) : (
			<div class="empty-state">
				<p class="empty-message">No essays published yet.</p>
				<a href={QUARTZ_URL} target="_blank" rel="noreferrer" class="empty-link">
					Browse the Quartz notes
					<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17L17 7m0 0H7m10 0v10"/></svg>
				</a>
			</div>
		)}

	</main>
	<Footer />
</body>
</html>

<style>
	main {
		max-width: 960px;
		margin: 0 auto;
		padding: 0 1.5rem 8rem;
	}

	/* ── Page hero ── */
	.page-hero {
		padding: 4rem 0 3.5rem;
	}

	.eyebrow {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		margin: 0 0 1.25rem;
		padding: 0.3rem 0.8rem;
		background: color-mix(in srgb, var(--accent) 10%, transparent);
		color: var(--accent);
		border-radius: 999px;
		font-size: 0.74rem;
		font-weight: 600;
		letter-spacing: 0.07em;
		text-transform: uppercase;
	}

	.bolt-icon {
		width: 7px;
		height: 10px;
		flex-shrink: 0;
	}

	h1 {
		margin: 0 0 1rem;
		font-size: clamp(2.5rem, 7vw, 4.25rem);
		font-weight: 800;
		line-height: 0.95;
		letter-spacing: -0.038em;
		color: rgb(var(--black));
	}

	[data-theme='dark'] h1 {
		text-shadow:
			0 0 50px color-mix(in srgb, var(--accent) 20%, transparent),
			0 0 100px color-mix(in srgb, var(--accent) 8%, transparent);
	}

	.lead {
		max-width: 520px;
		margin: 0;
		font-size: clamp(1rem, 2vw, 1.125rem);
		line-height: 1.68;
		color: rgb(var(--gray));
	}

	/* ── Posts section ── */
	.posts-section {
		padding-top: 1rem;
		position: relative;
	}

	.posts-section::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 1px;
		background: linear-gradient(
			90deg,
			transparent 0%,
			rgba(var(--gray), 0.18) 15%,
			rgba(0, 113, 227, 0.30) 50%,
			rgba(var(--gray), 0.18) 85%,
			transparent 100%
		);
	}

	[data-theme='dark'] .posts-section::before {
		background: linear-gradient(
			90deg,
			transparent 0%,
			rgba(var(--gray), 0.18) 15%,
			rgba(41, 151, 255, 0.40) 50%,
			rgba(var(--gray), 0.18) 85%,
			transparent 100%
		);
	}

	.posts-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1rem;
		padding-top: 2.5rem;
	}

	/* ── Empty state ── */
	.empty-state {
		padding: 5rem 0;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 1.25rem;
	}

	.empty-message {
		margin: 0;
		font-size: 1.125rem;
		color: rgb(var(--gray));
	}

	.empty-link {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		padding: 0.575rem 1.1rem;
		background: var(--accent);
		color: #fff !important;
		border-radius: 999px;
		font-size: 0.9rem;
		font-weight: 500;
		text-decoration: none !important;
		transition: opacity 0.18s ease, transform 0.18s ease;
	}
	.empty-link:hover { opacity: 0.85; transform: translateY(-1px); }

	/* ── Responsive ── */
	@media (max-width: 768px) {
		main { padding: 0 1.1rem 5rem; }

		.page-hero { padding: 3rem 0 2.5rem; }

		.posts-grid { grid-template-columns: 1fr; }
	}

	@media (max-width: 480px) {
		main { padding: 0 0.75rem 4rem; }
		.page-hero { padding: 2.5rem 0 2rem; }
	}
</style>
