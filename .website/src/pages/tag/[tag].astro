---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
	const posts = await getCollection('blog', ({ data }) => data.publish !== false);
	const tags = [...new Set(posts.flatMap(post => post.data.tags ?? []))];

	return [
		{ params: { tag: 'all' }, props: { posts, tag: 'all' } },
		...tags.map(tag => ({
			params: { tag },
			props: { posts: posts.filter(post => post.data.tags?.includes(tag)), tag },
		})),
	];
}

const { tag } = Astro.params;
const { posts } = Astro.props;

const sortedPosts = [...posts].sort((a, b) => {
	const dateA = a.data.created_date?.valueOf() ?? 0;
	const dateB = b.data.created_date?.valueOf() ?? 0;
	return dateB - dateA;
});

const isAll      = tag === 'all';
const pageTitle  = isAll ? 'All Writing' : `#${tag}`;
const pageDesc   = isAll
	? 'Essays and notes from EECS study, mathematics, and software systems.'
	: `Writing tagged with #${tag}.`;
---

<!doctype html>
<html lang="en">
<head>
	<BaseHead title={`${pageTitle} — Devansh Mahajan`} description={pageDesc} />
</head>
<body>
	<Header />
	<main>

		<section class="page-hero">
			<p class="eyebrow-tag">
				<svg viewBox="0 0 10 14" fill="currentColor" aria-hidden="true" style="width:7px;height:10px;flex-shrink:0"><path d="M6.5 0L0 8h4.5L3 14l7-8.5H5.5L6.5 0z"/></svg>
				{isAll ? 'Writing' : 'Tag'}
			</p>
			<h1>{pageTitle}</h1>
			<p class="lead">{pageDesc}</p>
		</section>

		{sortedPosts.length > 0 ? (
			<section class="section-rule">
				<div class="posts-grid">
					{sortedPosts.map((post) => (
						<BlogCard
							title={post.data.title}
							description={post.data.description ?? undefined}
							date={post.data.created_date}
							slug={post.data.slug ?? post.id}
						/>
					))}
				</div>
			</section>
		) : (
			<div class="empty-state">
				<p style="margin:0;font-size:1.125rem;color:rgb(var(--gray))">No posts tagged #{tag} yet.</p>
			</div>
		)}

	</main>
	<Footer />
</body>
</html>

<style>
	main {
		max-width: 960px;
		margin: 0 auto;
		padding: 0 1.5rem 8rem;
	}

	.page-hero { padding: 4rem 0 3.5rem; }

	h1 {
		margin: 0 0 1rem;
		font-size: clamp(2.5rem, 7vw, 4.25rem);
		font-weight: 800;
		line-height: 0.95;
		letter-spacing: -0.038em;
	}

	[data-theme='dark'] h1 {
		text-shadow:
			0 0 50px color-mix(in srgb, var(--accent) 20%, transparent),
			0 0 100px color-mix(in srgb, var(--accent) 8%, transparent);
	}

	.lead {
		max-width: 520px;
		margin: 0;
		font-size: clamp(1rem, 2vw, 1.125rem);
		line-height: 1.68;
		color: rgb(var(--gray));
	}

	.empty-state { padding: 5rem 0; }

	@media (max-width: 768px) {
		main { padding: 0 1.1rem 5rem; }
		.page-hero { padding: 3rem 0 2.5rem; }
	}
	@media (max-width: 480px) {
		main { padding: 0 0.75rem 4rem; }
		.page-hero { padding: 2.5rem 0 2rem; }
	}
</style>
