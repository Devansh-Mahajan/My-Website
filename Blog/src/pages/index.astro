		font-size: 5px;
		fill: currentColor;
		text-anchor: middle;
		opacity: 0.35;
	}

	/* SMD passive packages */
	.smd-pkg .ic-body, .crystal-pkg .ic-body { stroke: currentColor; fill: color-mix(in srgb, currentColor 5%, transparent); }

	/* Via ring style — annular ring, like plated through-holes */
	.vias circle:nth-child(odd)  {
		stroke: currentColor;
		stroke-width: 1.2;
		fill: none;
		animation: via-pulse 3s ease-in-out infinite;
	}
	.vias circle:nth-child(even) {
		fill: currentColor;
		opacity: 0.5;
		animation: via-pulse 3s ease-in-out infinite;
	}
	/* Stagger via pulses */
	.vias circle:nth-child(1),  .vias circle:nth-child(2)  { animation-delay: 0.0s; }
	.vias circle:nth-child(3),  .vias circle:nth-child(4)  { animation-delay: 0.4s; }
	.vias circle:nth-child(5),  .vias circle:nth-child(6)  { animation-delay: 0.9s; }
	.vias circle:nth-child(7),  .vias circle:nth-child(8)  { animation-delay: 1.4s; }
	.vias circle:nth-child(9),  .vias circle:nth-child(10) { animation-delay: 1.8s; }
	.vias circle:nth-child(11), .vias circle:nth-child(12) { animation-delay: 0.6s; }
	.vias circle:nth-child(13), .vias circle:nth-child(14) { animation-delay: 1.1s; }
	.vias circle:nth-child(15), .vias circle:nth-child(16) { animation-delay: 2.0s; }
	.vias circle:nth-child(17), .vias circle:nth-child(18) { animation-delay: 0.3s; }
	.vias circle:nth-child(19), .vias circle:nth-child(20) { animation-delay: 1.6s; }
	.vias circle:nth-child(21), .vias circle:nth-child(22) { animation-delay: 2.3s; }
	.vias circle:nth-child(23), .vias circle:nth-child(24) { animation-delay: 0.8s; }
	.vias circle:nth-child(25), .vias circle:nth-child(26) { animation-delay: 1.3s; }
	.vias circle:nth-child(27), .vias circle:nth-child(28) { animation-delay: 2.1s; }
	.vias circle:nth-child(29), .vias circle:nth-child(30) { animation-delay: 0.5s; }

	/* Signal pulses */
	.signal {
		fill: none;
		stroke: var(--accent);
		stroke-width: 2.5;
		opacity: 0;
	}
	.signal-a { stroke-dasharray: 16 480; animation: sig-a 5.2s linear infinite 0s; }
	.signal-b { stroke-dasharray: 16 260; animation: sig-b 3.4s linear infinite 1.8s; }
	.signal-c { stroke-dasharray: 16 390; animation: sig-c 4.8s linear infinite 3.0s; }
	.signal-d { stroke-dasharray: 16 355; animation: sig-d 4.4s linear infinite 0.9s; }

	/* Lightning bolts */
	.lb { fill: none; }
	.lb-1 { stroke: rgba(0, 113, 227, 0.13); stroke-width: 3; }
	.lb-2 { stroke: rgba(0, 113, 227, 0.08); stroke-width: 1.8; }
	[data-theme='dark'] .lb-1 { stroke: rgba(41, 151, 255, 0.24); }
