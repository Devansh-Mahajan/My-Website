---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BlogCard from '../components/BlogCard.astro';
import { QUARTZ_URL, SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';
import { getUrl } from '../utils/url';

const notes = {
	home: QUARTZ_URL,
	eecs: `${QUARTZ_URL}200-ETH-Zurich/ETH-BSc-EECS---Overview`,
	math: `${QUARTZ_URL}300-IMO-+-Putnam/Strategies-in-problem-solving`,
	programming: `${QUARTZ_URL}400-IOI/Competitive-Programming`,
	books: `${QUARTZ_URL}500-Book/Book-Notes`,
	quant: `${QUARTZ_URL}700-Quant/Quantitative-Work`,
	projects: `${QUARTZ_URL}800-Projects/Projects`,
};

const posts = (await getCollection('blog'))
	.filter((post) => post.data.publish)
	.sort((a, b) => {
		const dateA = a.data.created_date?.valueOf() ?? 0;
		const dateB = b.data.created_date?.valueOf() ?? 0;
		return dateB - dateA;
	})
	.slice(0, 3);

const hasPosts = posts.length > 0;

const selectedWork = [
	{
		title: 'ETH Zurich EECS notebook',
		meta: 'Coursework / circuits / systems',
		description:
			'A public engineering notebook for Electrical Engineering and Computer Science study at ETH Zurich.',
		href: notes.eecs,
	},
	{
		title: 'Competitive programming',
		meta: 'Algorithms / implementation',
		description:
			'IOI-style problem solving notes, templates, and techniques for writing reliable contest code.',
		href: notes.programming,
	},
	{
		title: 'Projects',
		meta: 'Build logs / design notes',
		description:
			'Technical project write-ups across electronics, software systems, and quantitative experiments.',
		href: notes.projects,
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="intro" aria-labelledby="intro-title">
				<p class="eyebrow">ETH Zurich / EECS</p>
				<h1 id="intro-title">Devansh Mahajan</h1>
				<p class="lead">
					Electrical Engineering and Computer Science student building a public notebook
					across circuits, mathematics, software systems, and quantitative work.
				</p>
				<div class="intro-actions">
					<a class="primary-link" href={notes.home} target="_blank" rel="noreferrer">
						Browse Notes Index
					</a>
					<a class="quiet-link" href="https://github.com/Devansh-Mahajan" target="_blank" rel="noreferrer">
						GitHub
					</a>
					<a class="quiet-link" href="https://www.linkedin.com/in/devansh-mahajan-2b2b99185/" target="_blank" rel="noreferrer">
						LinkedIn
					</a>
				</div>
			</section>

			<section class="section" aria-labelledby="work-title">
				<div class="section-heading">
					<p class="kicker">Selected Work</p>
					<h2 id="work-title">Things I am building and learning.</h2>
				</div>
				<div class="work-list">
					{selectedWork.map((item) => (
						<a class="work-row" href={item.href} target="_blank" rel="noreferrer">
							<span>
								<strong>{item.title}</strong>
								<small>{item.meta}</small>
							</span>
							<p>{item.description}</p>
						</a>
					))}
				</div>
			</section>

			<section class="section notes-section" aria-labelledby="notes-title">
				<div class="section-heading">
					<p class="kicker">Public Knowledge Base</p>
					<h2 id="notes-title">Quartz is the source of truth for notes.</h2>
				</div>
				<div class="notes-copy">
					<p>
						The landing site stays intentionally light. All notes, backlinks, graph views,
						search, and comments live in Quartz.
					</p>
					<a class="primary-link" href={notes.home} target="_blank" rel="noreferrer">Open Quartz</a>
				</div>
				<div class="index-links" aria-label="Quartz sections">
					<a href={notes.eecs} target="_blank" rel="noreferrer">200 ETH Zurich EECS</a>
					<a href={notes.math} target="_blank" rel="noreferrer">300 Problem Solving</a>
					<a href={notes.programming} target="_blank" rel="noreferrer">400 Competitive Programming</a>
					<a href={notes.books} target="_blank" rel="noreferrer">500 Book Notes</a>
					<a href={notes.quant} target="_blank" rel="noreferrer">700 Quantitative Work</a>
					<a href={notes.projects} target="_blank" rel="noreferrer">800 Projects</a>
				</div>
			</section>

			<section class="section capabilities" aria-labelledby="focus-title">
				<div class="section-heading">
					<p class="kicker">Focus</p>
					<h2 id="focus-title">A technical foundation across hardware and software.</h2>
				</div>
				<div class="focus-grid">
					<div>
						<strong>Electronics</strong>
						<p>Circuits, signals, digital logic, and physical systems.</p>
					</div>
					<div>
						<strong>Mathematics</strong>
						<p>Proofs, linear algebra, calculus, probability, and problem solving.</p>
					</div>
					<div>
						<strong>Software Systems</strong>
						<p>Clean implementation, automation, infrastructure, and data workflows.</p>
					</div>
					<div>
						<strong>Quantitative Work</strong>
						<p>Modelling, backtesting, statistics, and computational experiments.</p>
					</div>
				</div>
			</section>

			{hasPosts && (
				<section class="section" aria-labelledby="writing-title">
					<div class="section-heading">
						<p class="kicker">Writing</p>
						<h2 id="writing-title">Recent essays.</h2>
					</div>
					<div class="post-grid">
						{posts.map((post) => (
							<BlogCard
								title={post.data.title}
								description={post.data.description}
								date={post.data.created_date}
								slug={post.id}
							/>
						))}
					</div>
					<a class="quiet-link more-link" href={getUrl('/blog')}>All writing</a>
				</section>
			)}
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 960px;
		margin: 0 auto;
		padding: 0 1.5rem 6rem;
	}

	.intro {
		min-height: min(640px, calc(100vh - 4rem));
		display: flex;
		flex-direction: column;
		justify-content: center;
		padding: 4.5rem 0 3rem;
	}

	.eyebrow,
	.kicker {
		margin: 0 0 1rem;
		color: rgb(var(--gray));
		font-size: 0.85rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	h1,
	h2 {
		color: rgb(var(--black));
		letter-spacing: 0;
	}

	h1 {
		max-width: 840px;
		margin: 0;
		font-size: clamp(4rem, 10vw, 7.25rem);
		line-height: 0.92;
		font-weight: 700;
	}

	.lead {
		max-width: 680px;
		margin: 1.65rem 0 0;
		color: rgb(var(--gray-dark));
		font-size: clamp(1.15rem, 2vw, 1.45rem);
		line-height: 1.45;
		text-wrap: pretty;
	}

	.intro-actions {
		display: flex;
		align-items: center;
		gap: 1.25rem;
		flex-wrap: wrap;
		margin-top: 2rem;
	}

	.primary-link,
	.quiet-link {
		display: inline-flex;
		align-items: center;
		min-height: 2.75rem;
		text-decoration: none;
		font-weight: 600;
	}

	.primary-link {
		padding: 0 1.15rem;
		border-radius: 8px;
		background: rgb(var(--black));
		color: rgb(var(--gray-light));
	}

	.primary-link:hover {
		background: rgb(var(--gray-dark));
		text-decoration: none;
	}

	.quiet-link {
		color: rgb(var(--black));
	}

	.quiet-link:hover {
		color: var(--accent);
		text-decoration: none;
	}

	.section {
		padding: 5rem 0;
		border-top: 1px solid rgba(var(--gray), 0.18);
	}

	.section-heading {
		display: grid;
		grid-template-columns: 0.8fr 1.4fr;
		gap: 3rem;
		align-items: start;
		margin-bottom: 2.5rem;
	}

	.section-heading h2 {
		margin: 0;
		font-size: clamp(2rem, 4vw, 3.25rem);
		line-height: 1.05;
		font-weight: 700;
	}

	.work-list {
		display: grid;
		gap: 0;
		border-top: 1px solid rgba(var(--gray), 0.22);
	}

	.work-row {
		display: grid;
		grid-template-columns: minmax(180px, 0.8fr) 1.4fr;
		gap: 3rem;
		padding: 1.5rem 0;
		border-bottom: 1px solid rgba(var(--gray), 0.22);
		color: rgb(var(--black));
		text-decoration: none;
	}

	.work-row:hover {
		text-decoration: none;
	}

	.work-row strong {
		display: block;
		font-size: 1.05rem;
		line-height: 1.35;
	}

	.work-row small {
		display: block;
		margin-top: 0.35rem;
		color: rgb(var(--gray));
		font-size: 0.9rem;
	}

	.work-row p,
	.notes-copy p,
	.focus-grid p {
		margin: 0;
		color: rgb(var(--gray-dark));
		line-height: 1.65;
	}

	.notes-copy {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 2rem;
		margin-bottom: 2rem;
	}

	.notes-copy p {
		max-width: 580px;
		font-size: 1.1rem;
	}

	.index-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.65rem;
	}

	.index-links a {
		padding: 0.7rem 0.9rem;
		border: 1px solid rgba(var(--gray), 0.24);
		border-radius: 8px;
		color: rgb(var(--black));
		text-decoration: none;
		font-size: 0.95rem;
		font-weight: 600;
		background: rgba(var(--gray-light), 0.5);
	}

	.index-links a:hover {
		border-color: rgba(var(--gray-dark), 0.45);
		text-decoration: none;
	}

	.focus-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 2rem 3rem;
	}

	.focus-grid strong {
		display: block;
		margin-bottom: 0.5rem;
		color: rgb(var(--black));
		font-size: 1.05rem;
	}

	.post-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}

	.more-link {
		margin-top: 1.5rem;
	}

	[data-theme='dark'] .primary-link {
		background: rgb(var(--black));
		color: rgb(var(--gray-light));
	}

	[data-theme='dark'] .index-links a {
		background: rgba(var(--gray-light), 0.08);
	}

	@media (max-width: 760px) {
		main {
			padding: 0 1.1rem 4rem;
		}

		.intro {
			min-height: auto;
			padding: 5rem 0 3.5rem;
		}

		h1 {
			font-size: clamp(3.4rem, 18vw, 5rem);
		}

		.lead {
			max-width: 100%;
			font-size: 1.08rem;
			line-height: 1.55;
		}

		.intro-actions {
			gap: 0.8rem;
		}

		.primary-link {
			padding-inline: 0.95rem;
		}

		.section {
			padding: 3.75rem 0;
		}

		.section-heading,
		.work-row {
			grid-template-columns: 1fr;
			gap: 1rem;
		}

		.notes-copy {
			flex-direction: column;
		}

		.focus-grid,
		.post-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
