				<!-- Hero content -->
				<p class="eyebrow">
					<span class="status-dot" aria-hidden="true"></span>
					ETH Zurich &middot; EECS
				</p>

				<!-- Matrix scramble reveal on name -->
				<h1 id="hero-name">
					<span class="scramble-line">Devansh</span><br />
					<span class="scramble-line">Mahajan</span>
				</h1>

				<p class="lead">
					EECS student at ETH Zurich. Building a public notebook
					across circuits, mathematics, software systems, and
					quantitative work — everything is open.
				</p>

				<div class="hero-actions">
					<a class="btn-primary" href={notes.home} target="_blank" rel="noreferrer">
						Browse Notes
						<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17L17 7m0 0H7m10 0v10"/></svg>
					</a>
					<a class="btn-ghost" href="https://github.com/Devansh-Mahajan" target="_blank" rel="noreferrer">GitHub</a>
					<a class="btn-ghost" href="https://www.linkedin.com/in/devansh-mahajan-2b2b99185/" target="_blank" rel="noreferrer">LinkedIn</a>
				</div>

				<p class="hero-meta" aria-label="Status">
					<span>BSc Candidate</span>
					<span class="meta-sep" aria-hidden="true">/</span>
					<span>Spring 2026</span>
					<span class="meta-sep" aria-hidden="true">/</span>
					<span>Z&uuml;rich</span>
				</p>

			</section>

			<!-- ── 01 — SELECTED WORK ────────────────────── -->
			<section class="section" aria-labelledby="work-heading">
				<header class="section-header">
					<p class="label">
						<span class="label-num">
							<svg class="label-bolt-icon" viewBox="0 0 10 14" fill="currentColor" aria-hidden="true"><path d="M6.5 0L0 8h4.5L3 14l7-8.5H5.5L6.5 0z"/></svg>
							01
						</span>
						Selected Work
					</p>
					<h2 id="work-heading">Building in public.</h2>
				</header>

				<div class="work-grid">
					{selectedWork.map((item, i) => (
						<a
							class="work-card"
							href={item.href}
							target="_blank"
							rel="noreferrer"
							style={`animation-delay:${0.05 + i * 0.07}s`}
						>
							<p class="card-meta">{item.meta}</p>
							<h3>{item.title}</h3>
							<p class="card-desc">{item.description}</p>
							<span class="card-arrow" aria-hidden="true">
								<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
							</span>
						</a>
					))}
				</div>

				<nav class="notes-nav" aria-label="Notes index">
					<span class="notes-nav-label">Browse</span>
					<div class="note-tags" role="list">
						{noteLinks.map((link) => (
							<a class="note-tag" href={link.href} target="_blank" rel="noreferrer" role="listitem">
								{link.label}
							</a>
						))}
					</div>
					<a class="notes-all-link" href={notes.home} target="_blank" rel="noreferrer">
						All notes
						<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17L17 7m0 0H7m10 0v10"/></svg>
					</a>
				</nav>
			</section>

			<!-- ── 02 — FOCUS ────────────────────────────── -->
			<section class="section" aria-labelledby="focus-heading">
				<header class="section-header">
					<p class="label">
						<span class="label-num">
							<svg class="label-bolt-icon" viewBox="0 0 10 14" fill="currentColor" aria-hidden="true"><path d="M6.5 0L0 8h4.5L3 14l7-8.5H5.5L6.5 0z"/></svg>
							02
						</span>
						Focus
					</p>
					<h2 id="focus-heading">Technical foundations.</h2>
				</header>
				<div class="focus-grid">
					{focusAreas.map((area) => (
						<div class="focus-cell">
							<span class="cell-idx">{area.idx}</span>
							<strong>{area.title}</strong>
							<p>{area.description}</p>
						</div>
					))}
				</div>
			</section>

			<!-- ── 03 — WRITING ──────────────────────────── -->
			{hasPosts && (
				<section class="section" aria-labelledby="writing-heading">
					<header class="section-header">
						<p class="label">
							<span class="label-num">
								<svg class="label-bolt-icon" viewBox="0 0 10 14" fill="currentColor" aria-hidden="true"><path d="M6.5 0L0 8h4.5L3 14l7-8.5H5.5L6.5 0z"/></svg>
								03
							</span>
							Writing
						</p>
						<h2 id="writing-heading">Latest essays.</h2>
					</header>
					<div class="post-grid">
						{posts.map((post) => (
							<BlogCard
								title={post.data.title}
								description={post.data.description}
								date={post.data.created_date}
								slug={post.id}
							/>
						))}
					</div>
					<a class="more-link" href={getUrl('/blog')}>
						All writing
						<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
					</a>
				</section>
			)}

		</main>
		<Footer />
	</body>
</html>

<!-- Matrix scramble reveal for the hero name -->
<script>
  (() => {
    // EECS-flavored character set: Greek/math symbols, hex digits, logic chars
    const CHARS = 'ΩλΔμπΣφψαβγ0123456789ABCDEF#$@!?∀∃∈∇⊕';

    function scramble(el: HTMLElement, startDelay: number) {
      const final = el.textContent ?? '';
      const len = final.length;
      if (!len) return;

      const FRAMES   = 28;       // total animation frames
      const INTERVAL = 38;       // ms per frame (~26 fps)

      let frame = 0;

      // Pre-fill with scrambled chars so there's no flash of real text
      el.textContent = Array.from({ length: len }, (_, i) =>
        final[i] === ' ' ? ' ' : CHARS[Math.floor(Math.random() * CHARS.length)]
      ).join('');

      setTimeout(() => {
        const tick = () => {
          const locked = Math.floor((frame / FRAMES) * len);
          let out = '';
          for (let i = 0; i < len; i++) {
            if (i < locked || final[i] === ' ') {
              out += final[i];
            } else {
              out += CHARS[Math.floor(Math.random() * CHARS.length)];
            }
          }
          el.textContent = out;
          frame++;
          if (frame <= FRAMES) {
            setTimeout(tick, INTERVAL);
          } else {
            el.textContent = final;
          }
        };
        tick();
      }, startDelay);
    }

    const init = () => {
      const lines = document.querySelectorAll<HTMLElement>('.scramble-line');
      lines.forEach((line, i) => scramble(line, 120 + i * 160));
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init, { once: true });
    } else {
      init();
    }
  })();
</script>

<style>
	/* ═══════════════════════════════════════════════════════
	   KEYFRAMES
	   ═══════════════════════════════════════════════════════ */

	@keyframes fadeUp {
		from { opacity: 0; transform: translateY(16px); }
		to   { opacity: 1; transform: translateY(0); }
	}

	@keyframes status-pulse {
		0%, 100% { box-shadow: 0 0 0 0 rgba(48, 209, 88, 0.5); opacity: 1; }
		60%      { box-shadow: 0 0 0 5px rgba(48, 209, 88, 0);  opacity: 0.85; }
	}

	@keyframes via-pulse {
		0%, 100% { opacity: 0.20; }
		50%      { opacity: 0.55; }
	}

	@keyframes sig-a {
		0%   { stroke-dashoffset:   0; opacity: 0; }
		4%   { opacity: 1; }
		88%  { opacity: 1; }
		100% { stroke-dashoffset: -470; opacity: 0; }
	}
	@keyframes sig-b {
		0%   { stroke-dashoffset:   0; opacity: 0; }
		4%   { opacity: 1; }
		88%  { opacity: 1; }
		100% { stroke-dashoffset: -250; opacity: 0; }
	}
	@keyframes sig-c {
		0%   { stroke-dashoffset:   0; opacity: 0; }
		4%   { opacity: 1; }
		88%  { opacity: 1; }
		100% { stroke-dashoffset: -380; opacity: 0; }
	}
	@keyframes sig-d {
		0%   { stroke-dashoffset:   0; opacity: 0; }
		4%   { opacity: 1; }
		88%  { opacity: 1; }
		100% { stroke-dashoffset: -345; opacity: 0; }
	}

	@keyframes lc-anim-1 {
		0%   { stroke-dashoffset:   0; opacity: 0; }
		5%   { opacity: 1; }
		88%  { opacity: 1; }
		100% { stroke-dashoffset: -820; opacity: 0; }
	}
	@keyframes lc-anim-2 {
		0%   { stroke-dashoffset:   0; opacity: 0; }
		5%   { opacity: 1; }
		88%  { opacity: 1; }
		100% { stroke-dashoffset: -680; opacity: 0; }
	}

	/* ═══════════════════════════════════════════════════════
	   LAYOUT
	   ═══════════════════════════════════════════════════════ */

	main {
		max-width: 960px;
		margin: 0 auto;
		padding: 0 1.5rem 8rem;
	}

	/* ═══════════════════════════════════════════════════════
	   HERO
	   ═══════════════════════════════════════════════════════ */

	.hero {
		position: relative;
		min-height: min(680px, calc(100svh - 5rem));
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		padding-bottom: 5rem;
		overflow: hidden;
	}

	.hero-glow {
		position: absolute;
		top: -20%;
		left: -10%;
		width: 70%;
		max-width: 560px;
		aspect-ratio: 1;
		background: radial-gradient(ellipse at center,
			color-mix(in srgb, var(--accent) 9%, transparent) 0%,
			transparent 65%);
		pointer-events: none;
		z-index: 0;
	}

	/* ── PCB Circuit SVG ── */
	.circuit-bg {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		pointer-events: none;
		z-index: 0;
		color: rgba(0, 113, 227, 0.10);
	}

	[data-theme='dark'] .circuit-bg { color: rgba(41, 151, 255, 0.16); }

	/* Traces */
	.traces path  { stroke: currentColor; fill: none; }

	/* GND symbol */
	.gnd-sym line { stroke: currentColor; }

	/* IC footprint */
	.ic-body {
		stroke: currentColor;
		stroke-width: 1;
		fill: color-mix(in srgb, currentColor 4%, transparent);
	}
	.ic-pin1-mark {
		fill: currentColor;
		opacity: 0.5;
	}
	.ic-pad {
		stroke: currentColor;
		stroke-width: 0.8;
		fill: currentColor;
		opacity: 0.45;
	}
	.ic-divider {
		stroke: currentColor;
		stroke-width: 0.6;
		opacity: 0.4;
	}

	/* Reference designators */
	.ic-ref {
		font-family: 'JetBrains Mono', 'SF Mono', Consolas, monospace;
		font-size: 8.5px;
		fill: currentColor;
		text-anchor: middle;
		font-weight: 700;
		opacity: 0.85;
	}
	.ic-val {
		font-family: 'JetBrains Mono', 'SF Mono', Consolas, monospace;
		font-size: 5.5px;
		fill: currentColor;
		text-anchor: middle;
		opacity: 0.45;
		font-weight: 400;
	}
	.comp-ref {
		font-family: 'JetBrains Mono', 'SF Mono', Consolas, monospace;
		font-size: 6.5px;
		fill: currentColor;
		text-anchor: middle;
		opacity: 0.60;
	}
	.comp-val {
		font-family: 'JetBrains Mono', 'SF Mono', Consolas, monospace;
		font-size: 5px;
		fill: currentColor;
		text-anchor: middle;
