---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BlogCard from '../components/BlogCard.astro';
import { QUARTZ_URL, SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';
import { getUrl } from '../utils/url';

const notes = {
	home:        QUARTZ_URL,
	eecs:        `${QUARTZ_URL}200-ETH-Zurich/ETH-BSc-EECS---Overview`,
	math:        `${QUARTZ_URL}300-IMO-+-Putnam/Strategies-in-problem-solving`,
	programming: `${QUARTZ_URL}400-IOI/Competitive-Programming`,
	books:       `${QUARTZ_URL}500-Book/Book-Notes`,
	quant:       `${QUARTZ_URL}700-Quant/Quantitative-Work`,
	projects:    `${QUARTZ_URL}800-Projects/Projects`,
};

const posts = (await getCollection('blog'))
	.filter((post) => post.data.publish)
	.sort((a, b) => {
		const dateA = a.data.created_date?.valueOf() ?? 0;
		const dateB = b.data.created_date?.valueOf() ?? 0;
		return dateB - dateA;
	})
	.slice(0, 3);

const hasPosts = posts.length > 0;

const selectedWork = [
	{
		title: 'ETH Zurich EECS Notebook',
		meta: 'Circuits · Signals · Systems',
		description: 'EECS coursework notes — digital circuits, signal processing, linear systems, and computer architecture.',
		href: notes.eecs,
	},
	{
		title: 'Competitive Programming',
		meta: 'Algorithms · Complexity',
		description: 'Problem solving notes, algorithm templates, and contest techniques at IOI difficulty.',
		href: notes.programming,
	},
	{
		title: 'Projects',
		meta: 'Hardware · Software · Quant',
		description: 'Project logs across hardware, software systems, and quantitative experiments.',
		href: notes.projects,
	},
];

const noteLinks = [
	{ label: 'ETH Zurich EECS',        href: notes.eecs },
	{ label: 'Problem Solving',         href: notes.math },
	{ label: 'Competitive Programming', href: notes.programming },
	{ label: 'Book Notes',              href: notes.books },
	{ label: 'Quantitative Work',       href: notes.quant },
	{ label: 'Projects',                href: notes.projects },
];

const focusAreas = [
	{ idx: '01', title: 'Electronics',       description: 'Circuits, signals, digital logic, and physical systems.' },
	{ idx: '02', title: 'Mathematics',       description: 'Proofs, linear algebra, calculus, probability, and problem solving.' },
	{ idx: '03', title: 'Software Systems',  description: 'Clean implementation, automation, infrastructure, and data workflows.' },
	{ idx: '04', title: 'Quantitative Work', description: 'Modelling, backtesting, statistics, and computational experiments.' },
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>

			<!-- ── HERO ─────────────────────────────────── -->
			<section class="hero" aria-labelledby="hero-name">

				<!-- Ambient glow -->
				<div class="hero-glow" aria-hidden="true"></div>

				<!--
					PCB Schematic Background
					Orthogonal traces, IC footprints (U1/U2), passive components (R1/C1/Y1),
					ring-style vias, reference designators — full EECS character.
				-->
				<svg
					class="circuit-bg"
					viewBox="0 0 960 680"
					preserveAspectRatio="xMaxYMid meet"
					fill="none"
					xmlns="http://www.w3.org/2000/svg"
					aria-hidden="true"
				>
					<!-- ── Copper Traces ── -->
					<g class="traces" stroke="currentColor" stroke-width="1.2" fill="none" stroke-linecap="square">
						<!-- Power rail (top) -->
						<path d="M 960 60 H 880 V 88 H 812"/>
						<path d="M 750 0 V 55 H 880"/>
						<!-- Main horizontal bus at y=88 -->
						<path d="M 680 0 V 88"/>
						<path d="M 812 88 H 960"/>
						<!-- Right vertical bus -->
						<path d="M 812 88 V 148 H 960"/>
						<path d="M 812 148 V 315"/>
						<path d="M 812 315 H 960"/>
						<!-- U1 IC connections -->
						<path d="M 680 88 V 133"/>
						<path d="M 812 133 H 787"/>
						<path d="M 812 152 H 787"/>
						<path d="M 812 171 H 787"/>
						<path d="M 680 133 H 695"/>
						<path d="M 680 152 H 695"/>
						<path d="M 680 171 H 695"/>
						<!-- Branch traces -->
						<path d="M 812 242 H 722 V 315"/>
						<path d="M 600 335 H 722 V 450 H 600"/>
						<path d="M 812 315 V 395 V 500 H 660 V 560 H 960"/>
						<!-- U2 IC connections -->
						<path d="M 812 376 H 820"/>
						<path d="M 812 394 H 820"/>
						<path d="M 868 376 H 900 V 315"/>
						<path d="M 868 394 H 960"/>
						<!-- Crystal stub -->
						<path d="M 500 195 H 582 V 258 H 500"/>
						<!-- Lower bus -->
						<path d="M 660 560 V 628 H 800 V 680"/>
						<!-- GND stub -->
						<path d="M 722 450 V 490"/>
					</g>

					<!-- ── GND Symbols ── -->
					<g class="gnd-sym" stroke="currentColor" stroke-width="1" stroke-linecap="round">
						<line x1="722" y1="490" x2="722" y2="490"/>
						<line x1="714" y1="492" x2="730" y2="492"/>
						<line x1="717" y1="496" x2="727" y2="496"/>
						<line x1="720" y1="500" x2="724" y2="500"/>
					</g>

					<!-- ── IC U1 Footprint (8-pin SOIC / main FPGA) ── -->
					<g class="ic-pkg">
						<rect x="695" y="115" width="92" height="90" class="ic-body" rx="2"/>
						<!-- Pin 1 chamfer marker -->
						<path d="M 695 115 L 707 115 L 695 127 Z" class="ic-pin1-mark"/>
						<!-- Left pads (4 pins) — connected to traces -->
						<rect x="681" y="127" width="14" height="8"  class="ic-pad"/>
						<rect x="681" y="146" width="14" height="8"  class="ic-pad"/>
						<rect x="681" y="165" width="14" height="8"  class="ic-pad"/>
						<rect x="681" y="184" width="14" height="8"  class="ic-pad"/>
						<!-- Right pads (4 pins) -->
						<rect x="787" y="127" width="14" height="8"  class="ic-pad"/>
						<rect x="787" y="146" width="14" height="8"  class="ic-pad"/>
						<rect x="787" y="165" width="14" height="8"  class="ic-pad"/>
						<rect x="787" y="184" width="14" height="8"  class="ic-pad"/>
						<!-- Pin numbers -->
						<text x="692" y="134" class="pin-num">1</text>
						<text x="692" y="153" class="pin-num">2</text>
						<text x="692" y="172" class="pin-num">3</text>
						<text x="692" y="191" class="pin-num">4</text>
						<text x="793" y="134" class="pin-num">8</text>
						<text x="793" y="153" class="pin-num">7</text>
						<text x="793" y="172" class="pin-num">6</text>
						<text x="793" y="191" class="pin-num">5</text>
						<!-- Reference designator + value -->
						<text x="741" y="153" class="ic-ref">U1</text>
						<text x="741" y="165" class="ic-val">FPGA</text>
						<!-- Internal divider line -->
						<line x1="695" y1="157" x2="787" y2="157" class="ic-divider"/>
					</g>

					<!-- ── IC U2 Footprint (4-pin small package) ── -->
					<g class="ic-pkg">
						<rect x="820" y="362" width="48" height="46" class="ic-body" rx="1.5"/>
						<path d="M 820 362 L 829 362 L 820 371 Z" class="ic-pin1-mark"/>
						<!-- Left pads -->
						<rect x="807" y="370" width="13" height="7" class="ic-pad"/>
						<rect x="807" y="387" width="13" height="7" class="ic-pad"/>
						<!-- Right pads -->
						<rect x="868" y="370" width="13" height="7" class="ic-pad"/>
						<rect x="868" y="387" width="13" height="7" class="ic-pad"/>
						<!-- Labels -->
						<text x="844" y="387" class="ic-ref">U2</text>
						<text x="844" y="397" class="ic-val">MCU</text>
					</g>

					<!-- ── R1: SMD Resistor (inline on trace at y=88) ── -->
					<g class="smd-pkg">
						<rect x="834" y="82" width="26" height="12" class="ic-body" rx="1"/>
						<text x="847" y="78" class="comp-ref">R1</text>
						<text x="847" y="104" class="comp-val">10k</text>
					</g>

					<!-- ── C1: SMD Bypass Capacitor ── -->
					<g class="smd-pkg">
						<rect x="596" y="295" width="8" height="18" class="ic-body" rx="1"/>
						<!-- Cap polarity stripe -->
						<line x1="596" y1="295" x2="604" y2="295" class="ic-divider"/>
						<text x="608" y="306" class="comp-ref">C1</text>
						<text x="608" y="315" class="comp-val">100n</text>
					</g>

					<!-- ── Y1: Crystal Oscillator ── -->
					<g class="crystal-pkg">
						<rect x="536" y="207" width="34" height="40" class="ic-body" rx="3"/>
						<!-- Crystal symbol inside -->
						<rect x="545" y="216" width="16" height="22" class="ic-body" rx="0"/>
						<line x1="553" y1="212" x2="553" y2="216" class="ic-divider"/>
						<line x1="553" y1="238" x2="553" y2="242" class="ic-divider"/>
						<!-- Connecting stubs -->
						<line x1="536" y1="215" x2="530" y2="215" stroke="currentColor" stroke-width="1.2"/>
						<line x1="536" y1="245" x2="530" y2="245" stroke="currentColor" stroke-width="1.2"/>
						<line x1="530" y1="215" x2="530" y2="195" stroke="currentColor" stroke-width="1.2"/>
						<line x1="530" y1="245" x2="530" y2="258" stroke="currentColor" stroke-width="1.2"/>
						<text x="553" y="258" class="comp-ref">Y1</text>
					</g>

					<!-- ── Ring Vias / Solder Joints ── -->
					<g class="vias">
						<circle cx="812" cy="88"  r="5"/><circle cx="812" cy="88"  r="2"/>
						<circle cx="680" cy="88"  r="5"/><circle cx="680" cy="88"  r="2"/>
						<circle cx="880" cy="88"  r="5"/><circle cx="880" cy="88"  r="2"/>
						<circle cx="812" cy="148" r="5"/><circle cx="812" cy="148" r="2"/>
						<circle cx="812" cy="242" r="5"/><circle cx="812" cy="242" r="2"/>
						<circle cx="722" cy="242" r="5"/><circle cx="722" cy="242" r="2"/>
						<circle cx="722" cy="315" r="5"/><circle cx="722" cy="315" r="2"/>
						<circle cx="812" cy="315" r="5"/><circle cx="812" cy="315" r="2"/>
						<circle cx="812" cy="395" r="4"/><circle cx="812" cy="395" r="1.8"/>
						<circle cx="660" cy="500" r="4"/><circle cx="660" cy="500" r="1.8"/>
						<circle cx="660" cy="560" r="4"/><circle cx="660" cy="560" r="1.8"/>
						<circle cx="582" cy="195" r="4"/><circle cx="582" cy="195" r="1.8"/>
						<circle cx="582" cy="258" r="4"/><circle cx="582" cy="258" r="1.8"/>
						<circle cx="750" cy="55"  r="4"/><circle cx="750" cy="55"  r="1.8"/>
						<circle cx="900" cy="315" r="4"/><circle cx="900" cy="315" r="1.8"/>
					</g>

					<!-- ── Lightning Bolts (EECS energy, right edge) ── -->
					<g class="lightning-hero" fill="none" stroke-linecap="round" stroke-linejoin="round">
						<path class="lb lb-1" d="M 918,0 L 856,200 L 898,200 L 816,408 L 866,408 L 760,645"/>
						<path class="lb lb-2" d="M 960,55 L 928,235 L 955,235 L 914,432 L 944,432 L 896,622"/>
					</g>

					<!-- ── Traveling Signal Pulses ── -->
					<path class="signal signal-a" d="M 960 88  H 812 V 395"/>
					<path class="signal signal-b" d="M 680  0  V 88  H 960"/>
					<path class="signal signal-c" d="M 600 335 H 722 V 450 H 600"/>
					<path class="signal signal-d" d="M 812 395 V 500 H 660 V 560"/>

					<!-- Lightning charge pulses -->
					<path class="lc lc-1" stroke-linecap="round" stroke-linejoin="round"
						d="M 918,0 L 856,200 L 898,200 L 816,408 L 866,408 L 760,645"/>
					<path class="lc lc-2" stroke-linecap="round" stroke-linejoin="round"
						d="M 960,55 L 928,235 L 955,235 L 914,432 L 944,432 L 896,622"/>
